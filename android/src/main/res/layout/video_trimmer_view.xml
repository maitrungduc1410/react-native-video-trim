<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical">

  <FrameLayout
    android:id="@+id/headerView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/black"
    android:visibility="gone">

    <HorizontalScrollView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_gravity="center"
      android:scrollbars="none"
      android:fillViewport="true"
      android:paddingTop="6dp"
      android:paddingBottom="2dp">

      <TextView
        android:id="@+id/headerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:singleLine="true"
        android:text=""
        android:textColor="@android:color/white"
        android:textSize="16dp"
        android:paddingHorizontal="16dp" />
    </HorizontalScrollView>
  </FrameLayout>

  <LinearLayout
    android:id="@+id/transformRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_below="@+id/headerView"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:background="@android:color/black"
    android:gravity="center_vertical"
    android:visibility="gone">

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical">

      <ImageView
        android:id="@+id/flipBtn"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/arrow_trianglehead_left_and_right_righttriangle_left_righttriangle_right"
        android:tint="@android:color/white"
        android:scaleType="fitCenter"
        android:layout_marginEnd="12dp"
        android:contentDescription="Flip" />

      <ImageView
        android:id="@+id/rotateBtn"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/rotate_left"
        android:tint="@android:color/white"
        android:scaleType="fitCenter"
        android:layout_marginEnd="12dp"
        android:contentDescription="Rotate" />

      <ImageView
        android:id="@+id/cropBtn"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/crop"
        android:tint="#80FFFFFF"
        android:scaleType="fitCenter"
        android:contentDescription="Crop" />

      <ImageView
        android:id="@+id/muteBtn"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/speaker_wave_2_fill"
        android:tint="@android:color/white"
        android:scaleType="fitCenter"
        android:layout_marginStart="12dp"
        android:contentDescription="Mute" />

      <TextView
        android:id="@+id/speedBtn"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:text="1x"
        android:textColor="@android:color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginStart="12dp"
        android:contentDescription="Speed" />
    </LinearLayout>

    <View
      android:layout_width="0dp"
      android:layout_height="0dp"
      android:layout_weight="1" />

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical">

      <ImageView
        android:id="@+id/undoBtn"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/arrow_uturn_backward"
        android:tint="#80FFFFFF"
        android:scaleType="fitCenter"
        android:layout_marginEnd="12dp"
        android:contentDescription="Undo" />

      <ImageView
        android:id="@+id/redoBtn"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/arrow_uturn_forward"
        android:tint="#80FFFFFF"
        android:scaleType="fitCenter"
        android:contentDescription="Redo" />
    </LinearLayout>
  </LinearLayout>

  <FrameLayout
    android:id="@+id/videoContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_above="@+id/layout"
    android:layout_below="@+id/transformRow"
    android:background="@android:color/black"
    android:clipChildren="true"
    android:clipToPadding="false"
    android:paddingVertical="4dp">

    <TextureView
      android:id="@+id/video_loader"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_gravity="center" />

    <FrameLayout
      android:id="@+id/audioBannerView"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:layout_marginStart="50dp"
      android:layout_marginTop="50dp"
      android:layout_marginEnd="50dp"
      android:layout_marginBottom="50dp"
      android:padding="50dp"
      android:visibility="gone">

      <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:contentDescription="Airpods Max"
        android:src="@drawable/airpodsmax" />
    </FrameLayout>
  </FrameLayout>

  <RelativeLayout
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignParentBottom="true"
    android:background="@android:color/black">

    <RelativeLayout
      android:id="@+id/trimmerView"
      android:layout_width="match_parent"
      android:layout_height="50dp"
      android:layout_margin="8dp">

      <LinearLayout
        android:id="@+id/thumbnailContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal"
        android:padding="4dp" />

      <RelativeLayout
        android:id="@+id/trimmerContainerWrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
          android:id="@+id/trimmerContainerBg"
          android:layout_width="match_parent"
          android:layout_height="match_parent"
          android:layout_toStartOf="@id/trailingHandle"
          android:layout_toEndOf="@id/leadingHandle" />

        <RelativeLayout
          android:layout_width="match_parent"
          android:layout_height="match_parent">

          <View
            android:id="@+id/leadingOverlay"
            android:layout_width="20dp"
            android:layout_height="match_parent"
            android:layout_alignParentStart="true"
            android:background="@color/shadow_color" />

          <View
            android:id="@+id/trimmerContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_toStartOf="@id/trailingOverlay"
            android:layout_toEndOf="@id/leadingOverlay"
            android:background="@android:color/transparent" />

          <View
            android:id="@+id/progressIndicator"
            android:layout_width="10dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="20dp"
            android:background="@drawable/rounded_progress_indicator" />

          <View
            android:id="@+id/trailingOverlay"
            android:layout_width="20dp"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:background="@color/shadow_color" />
        </RelativeLayout>

        <FrameLayout
          android:id="@+id/leadingHandle"
          android:layout_width="20dp"
          android:layout_height="match_parent"
          android:layout_alignParentStart="true"
          android:layout_centerVertical="true"
          android:background="@android:color/transparent"
          android:paddingVertical="10dp">

          <ImageView
            android:id="@+id/leadingChevron"
            android:layout_width="20dp"
            android:layout_height="match_parent"
            android:contentDescription="LeadingHandle"
            android:src="@drawable/chevron_compact_left" />
        </FrameLayout>

        <FrameLayout
          android:id="@+id/trailingHandle"
          android:layout_width="20dp"
          android:layout_height="match_parent"
          android:layout_alignParentEnd="true"
          android:layout_centerVertical="true"
          android:background="@android:color/transparent"
          android:paddingVertical="10dp">

          <ImageView
            android:id="@+id/trailingChevron"
            android:layout_width="20dp"
            android:layout_height="match_parent"
            android:contentDescription="TrailingHandle"
            android:src="@drawable/chevron_compact_right" />
        </FrameLayout>
      </RelativeLayout>
    </RelativeLayout>

    <FrameLayout
      android:id="@+id/timingStackView"
      android:layout_width="match_parent"
      android:layout_height="50dp"
      android:layout_below="@+id/trimmerView"
      android:layout_marginHorizontal="16dp"
      android:orientation="horizontal"
      android:visibility="visible">

      <TextView
        android:id="@+id/startTime"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="left"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:padding="10dp"
        android:text="00:00.00"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

      <TextView
        android:id="@+id/currentTime"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:padding="10dp"
        android:text="00:00.00"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

      <TextView
        android:id="@+id/endTime"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="right"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:padding="10dp"
        android:text="00:00.00"
        android:textColor="@android:color/white"
        android:textSize="16sp" />
    </FrameLayout>

    <FrameLayout
      android:layout_width="match_parent"
      android:layout_height="50dp"
      android:layout_below="@+id/timingStackView"
      android:layout_marginLeft="10dp"
      android:layout_marginRight="10dp"
      android:orientation="horizontal"
      android:visibility="visible">

      <TextView
        android:id="@+id/cancelBtn"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="left"
        android:gravity="center"
        android:padding="10dp"
        android:text="@string/cancel"
        android:textColor="@android:color/white"
        android:textSize="16dp" />

      <ImageView
        android:id="@+id/icon_video_play"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:padding="12dp"
        android:src="@drawable/play_fill"
        android:tint="@color/white"
        android:visibility="gone" />

      <ImageView
        android:id="@+id/failToLoadBtn"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:padding="12dp"
        android:src="@drawable/exclamationmark_triangle_fill"
        android:tint="@color/trim_color"
        android:visibility="gone" />

      <ProgressBar
        android:id="@+id/loadingIndicator"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="10dp"
        android:indeterminateTint="@color/white" />

      <TextView
        android:id="@+id/saveBtn"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="right"
        android:gravity="center"
        android:padding="10dp"
        android:text="@string/save"
        android:textColor="#2196F3"
        android:textSize="16dp"
        android:visibility="gone" />
    </FrameLayout>
  </RelativeLayout>
</RelativeLayout>
